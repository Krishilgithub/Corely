generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String
  slug           String          @unique
  plan           String          @default("free")
  logoUrl        String?         @map("logo_url")
  settings       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  chatSessions   ChatSession[]
  documentChunks DocumentChunk[]
  documents      Document[]
  sources        Source[]
  users          User[]
  dashboardInsights DashboardInsight[]
  dashboardActions  DashboardAction[]
  orgMemories       OrgMemory[]

  @@map("workspaces")
}

model User {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  email       String    @unique
  name        String?
  avatarUrl   String?   @map("avatar_url")
  role        String    @default("member")
  preferences Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  sources     Source[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Source {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId  String     @map("workspace_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  type         String
  name         String
  status       String     @default("idle")
  errorMessage String?    @map("error_message")
  accessToken  String?    @map("access_token")
  refreshToken String?    @map("refresh_token")
  tokenExpiry  DateTime?  @map("token_expiry")
  lastSyncedAt DateTime?  @map("last_synced_at")
  itemsIndexed Int        @default(0) @map("items_indexed")
  config       Json       @default("{}")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  documents    Document[]
  user         User       @relation(fields: [userId], references: [id])
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("sources")
}

model Document {
  id          String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String          @map("workspace_id") @db.Uuid
  sourceId    String          @map("source_id") @db.Uuid
  externalId  String          @map("external_id")
  title       String
  fileType    String?         @map("file_type")
  url         String?
  rawContent  String?         @map("raw_content")
  indexedAt   DateTime?       @map("indexed_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  contentHash String?         @map("content_hash")
  chunks      DocumentChunk[]
  source      Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@map("documents")
}

model ChatSession {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  title       String
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  messages    ChatMessage[]
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  sender    String
  text      String
  sources   Json?
  feedback  String?
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model DocumentChunk {
  id          String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String                 @map("workspace_id") @db.Uuid
  documentId  String                 @map("document_id") @db.Uuid
  sourceId    String                 @map("source_id") @db.Uuid
  content     String
  chunkIndex  Int                    @map("chunk_index")
  tokenCount  Int?                   @map("token_count")
  metadata    Json                   @default("{}")
  createdAt   DateTime               @default(now()) @map("created_at")
  embedding   Unsupported("vector")?
  document    Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([embedding], map: "idx_chunks_embedding")
  @@map("document_chunks")
}

model DashboardInsight {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  priority    String    // 'HIGH', 'MEDIUM', 'LOW'
  title       String
  description String
  source      String
  iconType    String    @default("TrendingDown") // lucide icon name
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("dashboard_insights")
}

model DashboardAction {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  description String
  source      String
  iconType    String    @default("Cloud") // lucide icon name
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("dashboard_actions")
}

model OrgMemory {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  category    String    // 'decision', 'discussion', 'document', 'insight', 'knowledge'
  title       String
  content     String
  badges      Json      @default("[]") // Array of strings
  sourceName  String    @map("source_name")
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("org_memories")
}
